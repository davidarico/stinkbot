# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token
BOT_PREFIX=Wolf.

# Database Configuration
DATABASE_URL=postgresql://postgres:pasword@localhost:5432/stinkbot

# Postgres TLS (fixes SELF_SIGNED_CERT_IN_CHAIN for many local / WSL setups against Supabase):
# - Unset: strict verification (default in production).
# - Dev + hostname contains "supabase": bot relaxes TLS automatically (same idea as frontend).
# - DATABASE_SSL_REJECT_UNAUTHORIZED=false — always relax (use only if you understand the risk).
# - DATABASE_SSL_REJECT_UNAUTHORIZED=true — always strict (even in dev).
# DATABASE_SSL_REJECT_UNAUTHORIZED=

# v DEPRECATED DB USAGE v
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=your_db_user
# PG_DATABASE=your_db_name
# PG_PASSWORD=your_db_password

# MUST COMMENT OUT ANYTHING BELOW WHICH IS NOT BEING USED
# OpenAI Configuration (optional)
OPENAI_API_KEY=your_openai_api_key

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# S3 Configuration (optional - for archive summaries)
AWS_S3_BUCKET_NAME=your-archive-bucket

# OpenSearch Configuration (required for archiving)
OPENSEARCH_DOMAIN_ENDPOINT=https://search.yourdomain.com
OS_BASIC_USER=user1
OS_BASIC_PASS=YOUR_STRONG_PASSWORD

# Optional: Member sync logging
MEMBER_SYNC_LOG_CHANNEL_ID=your_log_channel_id

# When true, @Alive mention limits run only in the active game's town square (see alive-mention-detector)
ENABLE_ALIVE_MENTION_DETECTION=false
