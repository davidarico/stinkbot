# Database Configuration
# Copy this file to .env and update with your database credentials

# Option 1: Use DATABASE_URL (recommended for production and SSL connections)
# DATABASE_URL=postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/stinkbot

# Message archive database (optional). Archives live in a separate Postgres
# (self-hosted Pi, see CLAUDE.md "Archives"); when unset, archive reads/writes
# fall back to DATABASE_URL.
# ARCHIVE_DATABASE_URL=postgresql://stinkbot:password@dcc-pi.duckdns.org:5433/stinkbot_archive

# v DEPRECATED DB USAGE v
# Option 2: Use individual environment variables (used if DATABASE_URL is not set)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=stinkbot
# DB_USER=postgres
# DB_PASSWORD=your_password_here
